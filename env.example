# Update Center port
PORT=8600

# 宿主机上的更新数据目录（CI 会 rsync 上传到这个目录）
# 例如：/data/update_center/updates
UPDATE_DATA_DIR_HOST=/data/update_center/updates

# 容器内的更新数据目录（一般不用改）
UPDATE_DATA_DIR=/data/update_center/updates

# 管理面板 token（Bearer <token>）
UPDATE_ADMIN_TOKEN=please_change_me

# 可选：容器运行用户（默认 1001:1001）。如果宿主机目录权限不好处理，可临时改为 0:0（不推荐长期使用）。
UPDATE_CENTER_USER=1001:1001

# 若前面有 Nginx/1panel 反代，建议开
TRUST_PROXY=1
